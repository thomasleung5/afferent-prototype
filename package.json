{
  "name": "afferent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names client,api --prefix-colors blue,magenta \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "vite",
    "dev:api": "tsx watch --env-file=.env.local server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "test:cap": "tsx lib/data/__tests__/capStepDownGl.fixture.ts",
    "test:inst-depts": "tsx lib/data/__tests__/institutionalDepts.fixture.ts",
    "test:productive-hours": "tsx lib/__tests__/productiveHours.fixture.ts",
    "test:store-migration": "tsx lib/__tests__/storeMigration.fixture.ts",
    "test:capacity": "tsx lib/__tests__/capacity.fixture.ts",
    "test:fee-display": "tsx lib/__tests__/feeDisplay.fixture.ts",
    "test:calc": "tsx lib/__tests__/calc.fixture.ts",
    "test:fee-study": "tsx lib/__tests__/feeStudyCalculations.fixture.ts",
    "test:functional-allocation": "tsx lib/__tests__/functionalAllocation.fixture.ts",
    "test:ai-parser": "tsx server/__tests__/aiParseRunner.fixture.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@hono/node-server": "^2.0.2",
    "@tanstack/react-router": "^1.169.2",
    "hono": "^4.12.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.11"
  }
}
