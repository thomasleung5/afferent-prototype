{
  "name": "afferent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names client,api --prefix-colors blue,magenta \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "vite",
    "dev:api": "tsx watch --env-file=.env.local server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "node scripts/checkBuildEnv.mjs && vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist-server/index.mjs --packages=external --target=node22 --sourcemap=linked",
    "preview": "vite preview",
    "start": "node dist-server/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:cap && npm run test:inst-depts && npm run test:productive-hours && npm run test:store-migration && npm run test:capacity && npm run test:fee-display && npm run test:calc && npm run test:fee-study && npm run test:functional-allocation && npm run test:merge-imported-services && npm run test:xlsx-helpers && npm run test:excel-to-fees && npm run test:excel-to-domain && npm run test:ai-parser && npm run test:auth && npm run test:ai-upload && npm run test:ai-origin && npm run test:ai-rate-limit && npm run test:logger && npm run test:observability && npm run test:excel-preview && npm run test:env && npm run test:client-error-reporter && npm run test:snapshot-io && npm run test:snapshot-coercion && npm run test:study-validators && npm run test:study-authorization",
    "test:cap": "tsx lib/data/__tests__/capStepDownEngine.fixture.ts",
    "test:inst-depts": "tsx lib/data/__tests__/institutionalDepts.fixture.ts",
    "test:productive-hours": "tsx lib/__tests__/productiveHours.fixture.ts",
    "test:store-migration": "tsx lib/__tests__/storeMigration.fixture.ts",
    "test:capacity": "tsx lib/__tests__/capacity.fixture.ts",
    "test:fee-display": "tsx lib/__tests__/feeDisplay.fixture.ts",
    "test:calc": "tsx lib/__tests__/calc.fixture.ts",
    "test:fee-study": "tsx lib/__tests__/feeStudyCalculations.fixture.ts",
    "test:functional-allocation": "tsx lib/__tests__/functionalAllocation.fixture.ts",
    "test:merge-imported-services": "tsx lib/__tests__/mergeImportedServices.fixture.ts",
    "test:xlsx-helpers": "tsx lib/__tests__/xlsxHelpers.fixture.ts",
    "test:excel-to-fees": "tsx lib/__tests__/excelToFees.fixture.ts",
    "test:excel-to-domain": "tsx lib/__tests__/excelToDomain.fixture.ts",
    "test:ai-parser": "tsx server/__tests__/aiParseRunner.fixture.ts",
    "test:auth": "tsx server/__tests__/auth.fixture.ts",
    "test:ai-upload": "tsx server/__tests__/aiUploadValidator.fixture.ts",
    "test:ai-origin": "tsx server/__tests__/aiOriginGuard.fixture.ts",
    "test:ai-rate-limit": "tsx server/__tests__/aiRateLimit.fixture.ts",
    "test:logger": "tsx server/__tests__/logger.fixture.ts",
    "test:observability": "tsx server/__tests__/observability.fixture.ts",
    "test:excel-preview": "tsx server/__tests__/excelPreview.fixture.ts",
    "test:env": "tsx server/__tests__/env.fixture.ts",
    "test:client-error-reporter": "tsx lib/__tests__/clientErrorReporter.fixture.ts",
    "test:snapshot-io": "tsx lib/__tests__/snapshotIO.fixture.ts",
    "test:snapshot-coercion": "tsx lib/__tests__/snapshotCoercion.fixture.ts",
    "test:study-validators": "tsx server/__tests__/studyValidators.fixture.ts",
    "test:study-authorization": "tsx server/__tests__/studyAuthorization.fixture.ts",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@hono/node-server": "^2.0.2",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-router": "^1.169.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "read-excel-file": "^9.0.10",
    "write-excel-file": "^4.0.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
